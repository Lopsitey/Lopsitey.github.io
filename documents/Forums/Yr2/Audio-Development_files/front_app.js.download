;(function($){"use strict";ips.controller.mixin('events','core.front.core.commentFeed',true,function(){let currentCount,maxCount,_currentlyInEditingMode;const currentlyInEditingMode=()=>{if(_currentlyInEditingMode===undefined){_currentlyInEditingMode=!!window.location.href.toString().match(/^.*#editTopicSummary$/)}
return _currentlyInEditingMode};const postScoreAverage=()=>parseFloat(feedBlurb()?.dataset.postScoreAverage||'');const postIsInSummary=(postElem)=>{if(Number.isNaN(postScoreAverage())){return false;}
if(postElem.querySelector(`[data-commentid]`)?.dataset?.postForceInSummary){return true;}
if(isNaN(parseFloat(postElem.querySelector(`[data-commentid]`)?.dataset?.postScore))){return false;}
return parseFloat(postElem.querySelector(`[data-commentid]`).dataset.postScore)>=postScoreAverage();}
const feedID=this.scope.get(0).dataset.feedid
const feedBlurb=()=>feedID?document.querySelector(`[data-role="topicSummaryBlurb"][data-feedid="${encodeURIComponent(feedID)}"]`):undefined
const editSummaryButton=()=>feedID?feedBlurb()?.querySelector(`[href='#editTopicSummary']`):undefined
const editSummaryExitButton=()=>feedID?feedBlurb()?.querySelector(`[href='#editTopicSummaryExit']`):undefined
const getPostElements=()=>[...this.elem.querySelectorAll('[data-ips-hook="postWrapper"]')].filter(el=>el.querySelector(`.ipsEntry__content[data-commentid]`));const setupEditingMode=e=>{_currentlyInEditingMode=true;ips.utils.history.replaceState({editing:true},`topic_summary_${feedID}`,window.location.href.toString().replace(/^.*#[a-z0-9\-_\s#]*$/i,'#editTopicSummary'))
editSummaryExitButton()?.ipsShow();editSummaryButton()?.ipsHide();currentCount=parseInt(feedBlurb()?.dataset.summarySize);maxCount=parseInt(feedBlurb()?.dataset.maxSummarySize);for(const el of getPostElements()){if(!el.querySelector('.ipsTopicSummary_post_toggle')){const toggleMenu=document.createElement('div');toggleMenu.classList.add('ipsTopicSummary_post_toggle');if(!currentlyInEditingMode()){toggleMenu.ipsHide();}
toggleMenu.innerHTML=ips.templates.render('topic_summary_toggle_post');el.querySelector(`.ipsEntry__content .ipsEntry__meta`).appendChild(toggleMenu);el.querySelector(`[data-ips-hook="topicAuthorColumn"] .ipsEntry__header-align`)?.appendChild(toggleMenu.cloneNode(true));el.querySelectorAll('.ipsTopicSummary_post_toggle [data-role]').forEach(_el=>{_el.addEventListener('click',e=>{e.preventDefault();e.stopPropagation();addOrRemovePostInSummary(el,_el.dataset.role!=='remove')})})}
if(!postIsInSummary(el)){el.classList.add('ipsTopicSummary_post__disabled')
el.querySelector('[data-ips-hook="postContent"]').ipsDisable();el.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="add"]').ipsShow();el.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="remove"]').ipsHide();}else{el.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="add"]').ipsHide();el.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="remove"]').ipsShow();}
el.querySelectorAll('.ipsTopicSummary_post_toggle').ipsShow();el.querySelectorAll('.ipsEntry__meta .ipsEntry__topButton--ellipsis').ipsHide();el.querySelectorAll('[data-ips-hook="topicAuthorColumn"] :is(.ipsEntry__topButton--ellipsis, .ipsEntry__topButton--profile)').ipsHide();}
if((currentCount>=maxCount)){this.elem.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="add"]').ipsDisable({message:ips.getString('max_topic_summary_size_reached')});}else{this.elem.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="add"]').ipsEnable();}
this.elem.querySelectorAll(`[data-ipspagination] [data-page][href]`).forEach(el=>{el.setAttribute('href',el.getAttribute('href').replace(/^.*#[a-z0-9\-_\s]*$/,'')+'#editTopicSummary')})}
const exitEditingMode=e=>{e?.preventDefault();_currentlyInEditingMode=false;const url=window.location.href.toString().replace(/#editTopicSummary$/,'')
ips.utils.history.replaceState({editing:false},`topic_summary_${feedID}`,url)
editSummaryExitButton()?.ipsHide();editSummaryButton()?.ipsShow();for(const el of getPostElements()){el.classList.remove('ipsTopicSummary_post__disabled');el.querySelector('[data-ips-hook="postContent"]').ipsEnable();el.querySelectorAll('.ipsTopicSummary_post_toggle').ipsHide();el.querySelectorAll('.ipsEntry__meta .ipsEntry__topButton--ellipsis').ipsShow();el.querySelectorAll('[data-ips-hook="topicAuthorColumn"] :is(.ipsEntry__topButton--ellipsis, .ipsEntry__topButton--profile)').ipsShow();}
this.elem.querySelectorAll(`[data-ipspagination] [data-page][href]`).forEach(el=>{el.setAttribute('href',el.getAttribute('href').replace(/^.*#editTopicSummary$/,''))})}
const commentId=postEl=>parseInt(postEl.querySelector(`[data-commentid]`)?.dataset?.commentid);const addOrRemovePostInSummary=(post,add=true)=>{const url=window.location.href.toString();ips.getAjax()(url,{data:{comment:commentId(post),do:'addOrRemovePostFromSummary',add:!!add},method:"POST"}).done(data=>{if(add){post.dataset.postForceInSummary='1';post.classList.remove('ipsTopicSummary_post__disabled');post.querySelector('[data-ips-hook="postContent"]').ipsEnable();post.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="add"]').ipsHide();post.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="remove"]').ipsShow();}else{post.classList.add('ipsTopicSummary_post__disabled');post.dataset.postScore=""+data?.postScore;post.querySelector('[data-ips-hook="postContent"]').ipsDisable();delete post.dataset.postForceInSummary;post.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="add"]').ipsShow();post.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="remove"]').ipsHide();}
currentCount=data.count
maxCount=data.max;if((currentCount>=maxCount)){this.elem.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="add"]').ipsDisable({message:ips.getString('max_topic_summary_size_reached')});}else{this.elem.querySelectorAll('.ipsTopicSummary_post_toggle [data-role="add"]').ipsEnable();}}).fail(err=>{if(err.userMessage){ips.ui.alert.show({message:err.userMessage,buttons:{ok:ips.getString('ok')}});alert(`An error occurred: \n${err.userMessage}`);}})}
const init=()=>{editSummaryButton()?.addEventListener('click',setupEditingMode);editSummaryExitButton()?.addEventListener('click',exitEditingMode);if(currentlyInEditingMode()){setupEditingMode();}else{exitEditingMode();}}
if(editSummaryButton()&&editSummaryExitButton()){this.after('initialize',init)
$(document).on('contentChange',init)}});}(jQuery));;
;(function($){"use strict";ips.controller.mixin('events','core.front.core.dataLayer',true,function(){const originalSetup=this.setup;this.setup=(()=>{originalSetup.bind(this)();if(!(ipsSettings.features&&ipsSettings.features.analytics_full)){return;}
this.on('menuItemSelected',this.sortFilter);}).bind(this);const originalHandleEvent=this.handleEvent.bind(this);this.handleEvent=((evt,event)=>{if((event._analytics_full_only)&&!(ipsSettings.features&&ipsSettings.features.analytics_full)){return;}
return originalHandleEvent(evt,event);}).bind(this);const originalHandleProperties=this.handleProperties.bind(this);this.handleProperties=((evt,event)=>{if((event._analytics_full_only)&&!(ipsSettings.features&&ipsSettings.features.analytics_full)){return;}
